entor-widget-heading\" data-id=\"2606abc\" data-element_type=\"widget\" data-e-type=\"widget\" data-settings=\"{&quot;ekit_we_effect_on&quot;:&quot;none&quot;}\" data-widget_type=\"heading.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t<h2 class=\"elementor-heading-title elementor-size-default\">What our Travelers are saying<\/h2>\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t<\/div>\n\t\t<\/div>\n\t\t\t\t<div class=\"elementor-column elementor-col-50 elementor-top-column elementor-element elementor-element-49a1d02\" data-id=\"49a1d02\" data-element_type=\"column\" data-e-type=\"column\">\n\t\t\t<div class=\"elementor-widget-wrap elementor-element-populated\">\n\t\t\t\t\t\t<div class=\"elementor-element elementor-element-72a3eb5 elementor-widget elementor-widget-shortcode\" data-id=\"72a3eb5\" data-element_type=\"widget\" data-e-type=\"widget\" data-settings=\"{&quot;ekit_we_effect_on&quot;:&quot;none&quot;}\" data-widget_type=\"shortcode.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t\t\t<div class=\"elementor-shortcode\"><div class=\"wprev-no-slider\" id=\"wprev-slider-2\"><style>#wprev-slider-2 .wprev_preview_bradius_T1 {border-radius: 0px;}#wprev-slider-2 .wprev_preview_bg1_T1 {background:;}#wprev-slider-2 .wprev_preview_bg2_T1 {background:;}#wprev-slider-2 .wprev_preview_tcolor1_T1 {color:;}#wprev-slider-2 .wprev_preview_tcolor2_T1 {color:;}#wprev-slider-2 .wprev_preview_bg1_T1::after{ border-top: 30px solid ; }<\/style><style><\/style>\t\t<div class=\"wptripadvisor_t1_outer_div w3_wprs-row-padding\">\r\n\t\t\t\t<div class=\"wptripadvisor_t1_DIV_1 w3_wprs-col l4\">\r\n\t\t\t<div class=\"wptripadvisor_t1_DIV_2 wprev_preview_bg1_T1 wprev_preview_bradius_T1\">\r\n\t\t\t\t<p class=\"wptripadvisor_t1_P_3 wprev_preview_tcolor1_T1\">\r\n\t\t\t\t\t<span class=\"wptripadvisor_star_imgs_T1\"><img decoding=\"async\" src=\"https:\/\/dunetrektours.com\/wp-content\/plugins\/wp-tripadvisor-review-slider\/public\/partials\/imgs\/tripadvisor_stars_5.png\" alt=\"star rating\" class=\"wptripadvisor_t1_star_img_file\">&nbsp;&nbsp;<\/span><span class=\"wprevrevtitle\">A magical trip to Essaouira with Dune Trek Tours <\/span>&nbsp;-&nbsp;Our 2-night getaway to Essaouira was an unforgettable experience, thanks to DuneTrek Tours and the amazing Ismail, who was our driver and guide throughout the journey.<br \/>\r\n<br \/>\r\nFrom the moment<a class='wprs_rd_more'>... read more<\/a><span class='wprs_rd_more_text' style='display:none;'> we were picked up in Marrakech, Ismail ensured that everything was perfect. He is not only a skilled and safe driver but also incredibly friendly and knowledgeable about the region. The drive to Essaouira was smooth and filled with fascinating insights into Moroccan culture and history.<br \/>\r\n<br \/>\r\nEssaouira itself was a dream. We enjoyed serene yoga sessions by the beach and thrilling surfing lessons tailored to our skill levels. Everything was organized seamlessly by DuneTrek Tours, making the experience stress-free and truly magical.<br \/>\r\n<br \/>\r\nIsmail\u2019s warm hospitality and attention to detail made this trip one of the best we\u2019ve ever had. We highly recommend DuneTrek Tours for anyone looking to explore Morocco in comfort and style. Thank you, Ismail, for an incredible journey!<\/span>\t\t\t\t<\/p>\r\n\t\t\t\t\t\t\t\t<a href=\"https:\/\/www.tripadvisor.com\/Attraction_Review-g304018-d32715647-Reviews-Dune_Trek_Tours-Ouarzazate_Draa_Tafilalet.html\" target=\"_blank\" rel=\"nofollow\"><img decoding=\"async\" src=\"https:\/\/dunetrektours.com\/wp-content\/plugins\/wp-tripadvisor-review-slider\/public\/partials\/imgs\/tripadvisor_outline.png\" alt=\"tripadvisor logo\" class=\"wptripadvisor_t1_tripadvisor_logo\"><\/a>\t\t\t<\/div><span class=\"wptripadvisor_t1_A_8\"><img decoding=\"async\" src=\"https:\/\/media-cdn.tripadvisor.com\/media\/photo-l\/06\/cb\/dc\/ae\/9022marian.jpg\" alt=\"avatar thumb\" class=\"wptripadvisor_t1_IMG_4\" loading=\"lazy\"\/><\/span> <span class=\"wptripadvisor_t1_SPAN_5 wprev_preview_tcolor2_T1\">MariaJC1969-<br\/><span class=\"wprev_showdate_T1\">December 29, 2024<\/span> <\/span>\r\n\t\t<\/div>\r\n\t\t\t<div class=\"wptripadvisor_t1_DIV_1 w3_wprs-col l4\">\r\n\t\t\t<div class=\"wptripadvisor_t1_DIV_2 wprev_preview_bg1_T1 wprev_preview_bradius_T1\">\r\n\t\t\t\t<p class=\"wptripadvisor_t1_P_3 wprev_preview_tcolor1_T1\">\r\n\t\t\t\t\t<span class=\"wptripadvisor_star_imgs_T1\"><img decoding=\"async\" src=\"https:\/\/dunetrektours.com\/wp-content\/plugins\/wp-tripadvisor-review-slider\/public\/partials\/imgs\/tripadvisor_stars_5.png\" alt=\"star rating\" class=\"wptripadvisor_t1_star_img_file\">&nbsp;&nbsp;<\/span><span class=\"wprevrevtitle\">Magical days in Marrakech with dune trek tours <\/span>&nbsp;-&nbsp;Amazing Private Tour with DuneTrek Tours!<br \/>\r\nWe had an unforgettable private tour organized by DuneTrek Tours, and everything exceeded our expectations. The owner, Ismail, was incredibly kind, professional, and attentive,<a class='wprs_rd_more'>... read more<\/a><span class='wprs_rd_more_text' style='display:none;'> making the whole experience seamless.<br \/>\r\nOur English-speaking guide was fantastic\u2014very knowledgeable and friendly. We visited Bahia Palace, the vibrant souks, the historic Ben Youssef Madrasa, and the lively Jmaa El-Fna square. Every stop was well-planned, and we felt truly immersed in Moroccan culture.<br \/>\r\nWe highly recommend DuneTrek Tours for anyone visiting Morocco. The service, hospitality, and attention to detail were outstanding. Thank you, Ismail, for an amazing experience<\/span>\t\t\t\t<\/p>\r\n\t\t\t\t\t\t\t\t<a href=\"https:\/\/www.tripadvisor.com\/Attraction_Review-g304018-d32715647-Reviews-Dune_Trek_Tours-Ouarzazate_Draa_Tafilalet.html\" target=\"_blank\" rel=\"nofollow\"><img decoding=\"async\" src=\"https:\/\/dunetrektours.com\/wp-content\/plugins\/wp-tripadvisor-review-slider\/public\/partials\/imgs\/tripadvisor_outline.png\" alt=\"tripadvisor logo\" class=\"wptripadvisor_t1_tripadvisor_logo\"><\/a>\t\t\t<\/div><span class=\"wptripadvisor_t1_A_8\"><img decoding=\"async\" src=\"https:\/\/media-cdn.tripadvisor.com\/media\/photo-l\/1a\/f6\/e7\/3d\/default-avatar-2020-55.jpg\" alt=\"avatar thumb\" class=\"wptripadvisor_t1_IMG_4\" loading=\"lazy\"\/><\/span> <span class=\"wptripadvisor_t1_SPAN_5 wprev_preview_tcolor2_T1\">Rianna w<br\/><span class=\"wprev_showdate_T1\">January 18, 2025<\/span> <\/span>\r\n\t\t<\/div>\r\n\t\t\t<div class=\"wptripadvisor_t1_DIV_1 w3_wprs-col l4\">\r\n\t\t\t<div class=\"wptripadvisor_t1_DIV_2 wprev_preview_bg1_T1 wprev_preview_bradius_T1\">\r\n\t\t\t\t<p class=\"wptripadvisor_t1_P_3 wprev_preview_tcolor1_T1\">\r\n\t\t\t\t\t<span class=\"wptripadvisor_star_imgs_T1\"><img decoding=\"async\" src=\"https:\/\/dunetrektours.com\/wp-content\/plugins\/wp-tripadvisor-review-slider\/public\/partials\/imgs\/tripadvisor_stars_5.png\" alt=\"star rating\" class=\"wptripadvisor_t1_star_img_file\">&nbsp;&nbsp;<\/span><span class=\"wprevrevtitle\">Dunes with mum<\/span>&nbsp;-&nbsp;I went to the dunes with my mum and we had the best experience ever. The fire show was blowing! And I do love most the sunset.\t\t\t\t<\/p>\r\n\t\t\t\t\t\t\t\t<a href=\"https:\/\/www.tripadvisor.com\/Attraction_Review-g304018-d32715647-Reviews-Dune_Trek_Tours-Ouarzazate_Draa_Tafilalet.html\" target=\"_blank\" rel=\"nofollow\"><img decoding=\"async\" src=\"https:\/\/dunetrektours.com\/wp-content\/plugins\/wp-tripadvisor-review-slider\/public\/partials\/imgs\/tripadvisor_outline.png\" alt=\"tripadvisor logo\" class=\"wptripadvisor_t1_tripadvisor_logo\"><\/a>\t\t\t<\/div><span class=\"wptripadvisor_t1_A_8\"><img decoding=\"async\" src=\"https:\/\/media-cdn.tripadvisor.com\/media\/photo-l\/09\/11\/7e\/f8\/paola-c.jpg\" alt=\"avatar thumb\" class=\"wptripadvisor_t1_IMG_4\" loading=\"lazy\"\/><\/span> <span class=\"wptripadvisor_t1_SPAN_5 wprev_preview_tcolor2_T1\">Paola C<br\/><span class=\"wpre